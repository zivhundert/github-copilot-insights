# AI Chat Configuration (optional — enables the DevIntelligence chat feature)
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=
CHAT_MODEL=gemini-2.0-flash

# GitHub Enterprise API (optional — enables auto-fetch of Copilot metrics at build time)
# See: https://docs.github.com/en/enterprise-cloud@latest/rest/copilot
GITHUB_BASE_URL=
GITHUB_PAT=
GITHUB_ENTERPRISE=

# Exposed to the browser (tells the UI that pre-fetched data may exist)
VITE_GITHUB_ENTERPRISE=
